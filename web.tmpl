    <script type="application/javascript">

    globalThis.__canvas_resized = (self, ecw, ech) => {
        console.warn("TODO: panda3d canvas monitor", self, ecw, ech)
    }

    // PGN Move history bridge
    let moveList = [];

    window.resetMoves = function() {
        moveList = [];
        const table = document.getElementById('move-log-table');
        if (table) table.innerHTML = '';
        
        // Reset captures
        window.updateCaptured('{}', '{}');
    };

    window.addMove = function(san) {
        moveList.push(san);
        const table = document.getElementById('move-log-table');
        if (!table) return;
        
        // Re-render move table
        table.innerHTML = '';
        for (let i = 0; i < moveList.length; i += 2) {
            const moveNum = Math.floor(i / 2) + 1;
            const whiteMove = moveList[i];
            const blackMove = moveList[i + 1] || '';
            
            const row = document.createElement('div');
            row.className = 'move-row';
            row.innerHTML = `
                <span class="move-num">${moveNum}.</span>
                <span class="move-white">${whiteMove}</span>
                <span class="move-black">${blackMove}</span>
            `;
            table.appendChild(row);
        }
        
        // Auto scroll to bottom
        table.scrollTop = table.scrollHeight;
    };

    // Captured pieces bridge
    window.updateCaptured = function(whiteCapturedJson, blackCapturedJson) {
        const whiteCaptured = JSON.parse(whiteCapturedJson);
        const blackCaptured = JSON.parse(blackCapturedJson);
        
        const whiteList = document.getElementById('white-captures-list'); // Black pieces captured by White
        const blackList = document.getElementById('black-captures-list'); // White pieces captured by Black
        
        if (whiteList) {
            whiteList.innerHTML = '';
            // Black pieces captured: p, n, b, r, q
            const symbolMap = { 'p': '♟', 'n': '♞', 'b': '♝', 'r': '♜', 'q': '♛' };
            for (const [key, val] of Object.entries(blackCaptured)) {
                if (val > 0) {
                    const sym = symbolMap[key] || '';
                    const span = document.createElement('span');
                    span.className = 'captured-piece-black';
                    span.innerText = sym.repeat(val);
                    whiteList.appendChild(span);
                }
            }
        }
        
        if (blackList) {
            blackList.innerHTML = '';
            // White pieces captured: P, N, B, R, Q
            const symbolMap = { 'P': '♟', 'N': '♞', 'B': '♝', 'R': '♜', 'Q': '♛' };
            for (const [key, val] of Object.entries(whiteCaptured)) {
                if (val > 0) {
                    const sym = symbolMap[key] || '';
                    const span = document.createElement('span');
                    span.className = 'captured-piece-white';
                    span.innerText = sym.repeat(val);
                    blackList.appendChild(span);
                }
            }
        }
    };

